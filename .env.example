# ============================================================
#  SUPABASE
# ============================================================
# Project URL — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER-SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used only in the db:types script
SUPABASE_PROJECT_ID=your-project-id

# ============================================================
#  TWILIO — SERVER-SIDE ONLY
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15005550006

# ============================================================
#  APP
# ============================================================
# Base URL of this deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to sign internal API requests (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=replace-with-32-byte-random-hex
