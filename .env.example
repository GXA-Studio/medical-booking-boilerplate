# ============================================================
#  SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SERVICE ROLE — server-side ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PROJECT_ID=your-project-id

# ============================================================
#  TWILIO — SERVER-SIDE ONLY
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15005550006

# WhatsApp Sandbox (dev) — replace with approved number in production
# Sandbox: join at twilio.com/console/sms/whatsapp/sandbox
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================================
#  GMAIL — Lead notifications via SMTP
# ============================================================
# Cuando llega un lead a /api/leads, se envía un email a studiogxa@gmail.com.
# Requiere Gmail App Password (Account → Security → 2-Step Verification → App passwords).
# Si están vacíos, el lead se guarda en BD pero no se envía email.
GMAIL_APP_USER=studiogxa@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================================
#  UPSTASH REDIS — Rate limiting (C-01 security fix)
#  Get from: https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================================
#  CRON — protects /api/cron/reminders
#  Generate with: openssl rand -hex 32
#  Pass as: Authorization: Bearer <CRON_SECRET>
# ============================================================
CRON_SECRET=replace-with-32-byte-random-hex-from-openssl

# ============================================================
#  APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: default IANA timezone for clinics that have none set in the DB.
# Example: Europe/Madrid, America/Mexico_City, UTC
NEXT_PUBLIC_DEFAULT_TIMEZONE=Europe/Madrid
